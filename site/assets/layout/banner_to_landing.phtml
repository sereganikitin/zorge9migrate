<?php
/*
 * Floating "go to landing" CTA — one fixed button at the top-left of the
 * viewport, another fixed at the bottom-left.  Visible at any scroll position.
 *
 * $z9_banner_position = 'top' | 'bottom' — set by the caller before include.
 * The shared CSS is only emitted once (on the first include — `top` runs first
 * in page.phtml).
 */
$position = isset($z9_banner_position) ? $z9_banner_position : 'top';
$is_top = $position === 'top';
?>
<a class="z9-to-landing z9-to-landing--<?= htmlspecialchars($position) ?>"
   href="/" rel="nofollow">
    Открыть актуальный сайт ЖК Зорге 9 &nbsp;→
</a>
<?php if ($is_top): ?>
<style>
/* Floating CTA — always on top of Wolf's absolutely-positioned content */
.z9-to-landing {
    position: fixed;
    left: 20px;
    z-index: 99999;
    background: #c7a55a;
    color: #111;
    text-decoration: none;
    padding: 10px 18px;
    border-radius: 4px;
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 0 2px 12px rgba(0,0,0,.4);
    transition: background .15s ease, transform .15s ease;
}
.z9-to-landing:hover { background: #d8b96e; color: #111; transform: translateY(-1px); }
.z9-to-landing--top    { top: 20px; }
.z9-to-landing--bottom { bottom: 20px; }

@media (max-width: 640px) {
    .z9-to-landing { left: 12px; padding: 9px 14px; font-size: 13px; }
    .z9-to-landing--top    { top: 12px; }
    .z9-to-landing--bottom { bottom: 12px; }
}

/* Hide leftover sidebar wrappers — Wolf used the right edge for the menu,
   social, art3d link. With menu removed they are blank space; force them out
   and let the main content use the full viewport width. */
.logo, .art3d, .menu_frame, .menu_phone, .menu_wrap, .menu_list,
.social, .menu_bottom { display: none !important; }

/* Take back the room the sidebar used to reserve.  Several variants of
   Wolf's CSS pin these elements to a fixed right inset — clear it. */
#body_frame, #centrer1, #centrer2, .load_frame_content, .load_frame,
.resizable, .not-resizable {
    right: 0 !important;
    left: 0 !important;
    width: 100% !important;
    max-width: 100vw !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
}
</style>
<?php endif; ?>
