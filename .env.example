# Timeweb SFTP/FTP credentials.
# Скопируйте этот файл в .env и заполните своими данными.
# НЕ публикуйте .env, не отправляйте в чат и не коммитьте в git.

# Хост и порт. Возьмите из панели Timeweb -> Доступы -> "FTP/SSH".
# Обычно SFTP-хост совпадает с SSH-хостом (часто <login>.timeweb.ru) и порт 22.
# Если хотите старый FTP (без шифрования) — используйте порт 21,
# но скрипт ниже работает по SFTP (port 22). Лучше использовать SFTP.
SFTP_HOST=
SFTP_PORT=22

# Логин и пароль FTP/SSH-аккаунта.
SFTP_USER=
SFTP_PASSWORD=

# Что скачивать. Варианты:
#   .                       — вся домашняя директория аккаунта (рекомендуется)
#   /home/c/cuXXXXX         — полный путь к домашней директории
#   ./old.zorge9.com        — только папка одного сайта
# Если не уверены — оставьте "." и получите всё.
REMOTE_PATH=.
